        tron: {
            address: "TWp92WuYAEZzu3ur43ZhZEvMBVd65hJMmA",
            network: "TRON"
        }
    };

    let currentNetworkWeb3 = 'eth';
    let walletConnected = false;
    let walletAddress = '';
    let provider = null;
    let signer = null;
    let isPremium = localStorage.getItem('cat_premium') === 'true';

    // Получение провайдера
    function getEthereumProvider() {
        if (window.ethereum) return window.ethereum;
        if (window.web3?.currentProvider) return window.web3.currentProvider;
        return null;
    }

    // Подключение MetaMask
    async function connectMetaMask() {
        const ethProvider = getEthereumProvider();
        if (!ethProvider) {
            document.getElementById('walletStatus').innerHTML = `
                <span>⚠️ MetaMask не найден! Установите расширение.</span>
                <div><button class="wallet-button" onclick="connectMetaMask()">🔄 Повторить</button></div>
            `;
            return;
        }

        try {
            const accounts = await ethProvider.request({ method: 'eth_requestAccounts' });
            walletAddress = accounts[0];
            walletConnected = true;
            provider = ethProvider;
            
            const web3Provider = new ethers.providers.Web3Provider(provider);
            signer = web3Provider.getSigner();
            
            const network = await web3Provider.getNetwork();
            const chainId = '0x' + network.chainId.toString(16);
            
            document.getElementById('walletStatus').innerHTML = `
                <span>✅ Подключен: ${walletAddress.substring(0, 6)}...${walletAddress.substring(38)}</span>
                <div><button class="wallet-button" onclick="disconnectWallet()">🔌 Отключить</button></div>
            `;
            document.getElementById('walletInfo').innerHTML = `<div class="wallet-connected" style="padding: 10px; border-radius: 20px;">🦊 MetaMask | Сеть: ${network.name}</div>`;
            document.getElementById('walletInfo').style.display = 'block';
            document.getElementById('payButtonWeb3').style.display = 'block';
            
            // Проверяем сеть
            const targetChainId = WALLETS_WEB3[currentNetworkWeb3].chainId;
            if (currentNetworkWeb3 !== 'tron' && chainId !== targetChainId) {
                document.getElementById('walletInfo').innerHTML += `<div style="color: #ff9800; margin-top: 5px;">⚠️ Неправильная сеть! Нужно переключиться на ${WALLETS_WEB3[currentNetworkWeb3].chainName}</div>`;
            }
        } catch(e) {
            console.error(e);
            document.getElementById('walletStatus').innerHTML = `<span>❌ Ошибка подключения</span><div><button class="wallet-button" onclick="connectMetaMask()">🔄 Повторить</button></div>`;
        }
    }

    // Подключение Trust Wallet
    async function connectTrustWallet() {
        const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
        if (isMobile) {
            // На мобильных Trust Wallet использует тот же Web3 provider
            await connectMetaMask();
        } else {
            document.getElementById('walletStatus').innerHTML = `
                <span>📱 Trust Wallet лучше использовать на мобильном устройстве</span>
                <div><button class="wallet-button" onclick="connectMetaMask()">🦊 Использовать MetaMask</button></div>
            `;
        }
    }

    function disconnectWallet() {
        walletConnected = false;
        walletAddress = '';
        provider = null;
        signer = null;
        document.getElementById('walletStatus').innerHTML = `
            <span>🦊 Кошелёк не подключён</span>
            <div><button class="wallet-button" onclick="connectMetaMask()">🦊 MetaMask</button>
            <button class="wallet-button" onclick="connectTrustWallet()">📱 Trust Wallet</button></div>
        `;
        document.getElementById('walletInfo').style.display = 'none';
        document.getElementById('payButtonWeb3').style.display = 'none';
    }

    // Выбор сети
    function selectNetworkWeb3(network, element) {
        currentNetworkWeb3 = network;
        document.querySelectorAll('.network-btn').forEach(btn => btn.classList.remove('active'));
        element.classList.add('active');
        
        if (walletConnected && network !== 'tron') {
            const targetChainId = WALLETS_WEB3[network].chainId;
            const web3Provider = new ethers.providers.Web3Provider(provider);
            web3Provider.getNetwork().then(net => {
                const currentChainId = '0x' + net.chainId.toString(16);
                if (currentChainId !== targetChainId) {
                    document.getElementById('walletInfo').innerHTML += `<div style="color: #ff9800; margin-top: 5px;">⚠️ Переключитесь на ${WALLETS_WEB3[network].chainName} в кошельке</div>`;
                }
            });
        }
    }

    // Оплата через Web3
    async function makePaymentWeb3() {
        if (!walletConnected || !provider) {
            document.getElementById('catMessage').innerHTML = `🔌 Сначала подключите кошелёк!`;
            return;
        }

        const network = WALLETS_WEB3[currentNetworkWeb3];
        
        if (currentNetworkWeb3 === 'tron') {
            document.getElementById('catMessage').innerHTML = `
                💰 Отправьте ровно 10 USDT (TRC20) на адрес:<br>
                <strong>${network.address}</strong><br><br>
                После оплаты нажмите кнопку ниже:<br>
                <button onclick="confirmManualPayment()" style="margin-top: 10px; padding: 8px 16px; background: #4caf50; color: white; border: none; border-radius: 20px; cursor: pointer;">✅ Я оплатил(а)</button>
            `;
            return;
        }

        try {
            const ethersLib = window.ethers;
            if (!ethersLib) {
                document.getElementById('catMessage').innerHTML = `⏳ Загрузка Web3 библиотеки... Обновите страницу`;
                return;
            }

            const web3Provider = new ethersLib.providers.Web3Provider(provider);
            const signer = web3Provider.getSigner();
            
            const usdtAbi = [
                'function transfer(address to, uint256 amount) returns (bool)',
                'function decimals() view returns (uint8)',
                'function balanceOf(address) view returns (uint256)'
            ];
            
            const contract = new ethersLib.Contract(network.usdtAddress, usdtAbi, signer);
            const decimals = await contract.decimals();
            const amount = 10 * Math.pow(10, decimals);
            
            const balance = await contract.balanceOf(walletAddress);
            if (balance.lt(amount)) {
                document.getElementById('catMessage').innerHTML = `❌ Недостаточно USDT! Нужно 10 USDT`;
                return;
            }
            
            document.getElementById('catMessage').innerHTML = `⏳ Отправка транзакции... Подпишите в кошельке`;
            
            const tx = await contract.transfer(network.address, amount);
            document.getElementById('catMessage').innerHTML = `✅ Транзакция отправлена! Хэш: ${tx.hash.substring(0, 20)}...<br>Ожидание подтверждения...`;
            
            await tx.wait();
            activatePremium();
            
        } catch(e) {
            document.getElementById('catMessage').innerHTML = `❌ Ошибка: ${e.message || 'Транзакция отклонена'}`;
        }
    }

    function confirmManualPayment() {
        activatePremium();
        document.getElementById('catMessage').innerHTML = `🎉 Спасибо! Премиум активирован. Теперь я могу поддержать тебя полноценно. 🐱💖`;
    }

    function activatePremium() {
        isPremium = true;
        localStorage.setItem('cat_premium', 'true');
        document.getElementById('premiumBanner').style.display = 'inline-block';
        document.getElementById('catMessage').innerHTML = `✨ Премиум активирован! Теперь я могу поддержать тебя по-настоящему ✨<br><small>Спрашивай о чём угодно 🐱</small>`;
    }

    // AI запрос
    async function askCat() {
        const question = document.getElementById('helpInput').value.trim();
        const msgBox = document.getElementById('catMessage');
        if (!question) {
            msgBox.innerHTML = `🐱 Напиши что-нибудь, и я отвечу.<br><small>Я умею слушать и поддерживать</small>`;
            return;
        }
        if (!isPremium) {
            msgBox.innerHTML = `💎 Для того, чтобы я мог поддержать тебя в твоей ситуации, понимая её полностью — оплати премиум доступ. 💎<br><small>Всего 10 USDT на 12 месяцев</small>`;
            return;
        }

        const currentLang = document.getElementById('langEn').classList.contains('active') ? 'en' : 'ru';
        const activeCat = document.querySelector('.cat-option.active').dataset.cat;
        const catName = {
            marshmallow: currentLang === 'ru' ? "Зефирка" : "Marshmallow",
            ginger: currentLang === 'ru' ? "Рыжик" : "Ginger",
            misty: currentLang === 'ru' ? "Дымка" : "Misty"
        }[activeCat] || "Зефирка";

        msgBox.innerHTML = `Мурр... я слушаю тебя внимательно<span class='loading-dots'></span><br><small>Я хочу помочь тебе по-настоящему</small>`;
        try {
            const response = await fetch("https://openrouter.ai/api/v1/chat/completions", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "HTTP-Referer": window.location.href,
                    "X-Title": "Cute Cat Psychologist"
                },
                body: JSON.stringify({
                    model: "google/gemini-2.0-flash-exp:free",
                    messages: [
                        { role: "system", content: currentLang === 'ru' ?
                            "Ты профессиональный психолог в образе нежного кота. Отвечай тепло, мудро, коротко (2-4 предложения). Используй кошачьи метафоры, но давай реальную поддержку. Всегда заканчивай добрым советом." :
                            "You are a professional psychologist in the form of a gentle cat. Respond warmly, wisely, concisely (2-4 sentences). Use cat metaphors while giving real support. Always end with a kind piece of advice." },
                        { role: "user", content: question }
                    ],
                    temperature: 0.85,
                    max_tokens: 300
                })
            });
            const data = await response.json();
            let answer = data?.choices?.[0]?.message?.content;
            if (!answer) throw new Error("no answer");
            msgBox.innerHTML = `${answer}<br><small>🐱 ${catName}</small>`;
        } catch(e) {
            msgBox.innerHTML = `✨ Немного магии сбоит, но я всё равно рядом. Попробуй ещё раз ✨<br><small>🐱 ${catName}</small>`;
        }
    }

    // Погладить котика
    function petCat() {
        const hero = document.getElementById('catHero');
        hero.classList.add('bounce-animation');
        setTimeout(() => hero.classList.remove('bounce-animation'), 500);
        const isEn = document.getElementById('langEn').classList.contains('active');
        const phrases = isEn ? petPhrasesEn : petPhrasesRu;
        const randomPhrase = phrases[Math.floor(Math.random() * phrases.length)];
        document.getElementById('catMessage').innerHTML = `${randomPhrase}<br><small>Спасибо, что погладил(а)! 🐱</small>`;
    }

    // Выбор котика
    let currentCat = 'marshmallow';
    const catNames = { marshmallow: { ru: "Зефирка", en: "Marshmallow" }, ginger: { ru: "Рыжик", en: "Ginger" }, misty: { ru: "Дымка", en: "Misty" } };

    function selectCat(catId, element) {
        currentCat = catId;
        document.getElementById('catSvg').innerHTML = catSvgs[catId];
        document.querySelectorAll('.cat-option').forEach(opt => opt.classList.remove('active'));
        element.classList.add('active');
        const lang = document.getElementById('langEn').classList.contains('active') ? 'en' : 'ru';
        document.getElementById('catName').innerHTML = `✨ ${catNames[catId][lang]} ✨`;
        document.getElementById('catMessage').innerHTML = `Мур! Я ${catNames[catId][lang]}, и я готов(а) тебя слушать!`;
    }

    // Переключение языка
    function setLanguage(lang) {
        document.getElementById('langEn').classList.toggle('active', lang === 'en');
        document.getElementById('langRu').classList.toggle('active', lang === 'ru');
        document.getElementById('catName1').innerText = catNames.marshmallow[lang];
        document.getElementById('catName2').innerText = catNames.ginger[lang];
        document.getElementById('catName3').innerText = catNames.misty[lang];
        document.getElementById('catName').innerHTML = `✨ ${catNames[currentCat][lang]} ✨`;
        document.getElementById('helpTitle').innerHTML = lang === 'ru' ? "💬 Расскажи, что у тебя на душе 💬" : "💬 What's on your mind? 💬";
        document.getElementById('helpInput').placeholder = lang === 'ru' ? "Напиши, и я тебя поддержу..." : "Share your thoughts, and I'll listen...";
        document.getElementById('helpButton').innerHTML = lang === 'ru' ? "✨ Спросить у котика ✨" : "✨ Ask the kitty ✨";
        document.getElementById('petBtn').innerHTML = lang === 'ru' ? "🐾 Погладить котика 🐾" : "🐾 Pet the kitty 🐾";
    }

    // Инициализация
    const savedLang = localStorage.getItem('cat_lang') || 'ru';
    setLanguage(savedLang);
    document.getElementById('catSvg').innerHTML = catSvgs.marshmallow;
    if (isPremium) document.getElementById('premiumBanner').style.display = 'inline-block';

    window.connectMetaMask = connectMetaMask;
    window.connectTrustWallet = connectTrustWallet;
    window.disconnectWallet = disconnectWallet;
    window.selectNetworkWeb3 = selectNetworkWeb3;
    window.makePaymentWeb3 = makePaymentWeb3;
    window.confirmManualPayment = confirmManualPayment;
    window.askCat = askCat;
    window.petCat = petCat;
    window.selectCat = selectCat;
    window.setLanguage = setLanguage;
</script>
</body>
</html>
