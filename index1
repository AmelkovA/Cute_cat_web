    const petPhrasesEn = [
        "You're already amazing just for being here. 🌸",
        "Sometimes a deep breath is all you need. I'm right here.",
        "Every day is a new page. Write it with kindness toward yourself.",
        // ... здесь все 100 фраз (в финальном коде они будут)
    ];

