270" cy="215" rx="20" ry="12" fill="#ffddb0" opacity="0.7"/><path d="M90 270 L70 285 L85 300 L105 285 Z" fill="#ffcd94" stroke="#e68a2e" stroke-width="2"/><path d="M310 330 Q330 320 335 300 Q340 280 325 285 Q315 290 310 310 Z" fill="#ffcd94" stroke="#e68a2e" stroke-width="2"/></svg>`,
        misty: `<svg viewBox="0 0 400 400"><defs><radialGradient id="furGradient" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#e0e7ed"/><stop offset="100%" stop-color="#cfd9e2"/></radialGradient><filter id="softShadow" x="-0.02" y="-0.02" width="1.04" height="1.04"><feGaussianBlur in="SourceAlpha" stdDeviation="3"/><feOffset dx="2" dy="2"/><feComponentTransfer><feFuncA type="linear" slope="0.3"/></feComponentTransfer><feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs><path d="M120 100 L80 40 L140 80 Z" fill="#cbd7e4" stroke="#8f9eb0" stroke-width="3"/><path d="M280 100 L320 40 L260 80 Z" fill="#cbd7e4" stroke="#8f9eb0" stroke-width="3"/><ellipse cx="200" cy="210" rx="135" ry="125" fill="url(#furGradient)" stroke="#8f9eb0" stroke-width="3" filter="url(#softShadow)"/><g class="cat-eyes"><ellipse cx="150" cy="185" rx="16" ry="22" fill="#fff" stroke="#5a6e7c" stroke-width="2"/><ellipse cx="250" cy="185" rx="16" ry="22" fill="#fff" stroke="#5a6e7c" stroke-width="2"/><circle cx="154" cy="190" r="7" fill="#2c3e4e"/><circle cx="254" cy="190" r="7" fill="#2c3e4e"/><circle cx="151" cy="187" r="2.5" fill="white"/><circle cx="251" cy="187" r="2.5" fill="white"/></g><ellipse cx="200" cy="215" rx="18" ry="14" fill="#b7c3d1" stroke="#8f9eb0" stroke-width="2"/><path d="M180 235 Q200 260 220 235" fill="none" stroke="#8f9eb0" stroke-width="6" stroke-linecap="round"/><circle cx="174" cy="241" r="5" fill="#b7c3d1" opacity="0.5"/><circle cx="226" cy="241" r="5" fill="#b7c3d1" opacity="0.5"/><path d="M120 210 L70 205" stroke="#8f9eb0" stroke-width="2"/><path d="M120 220 L70 220" stroke="#8f9eb0" stroke-width="2"/><path d="M120 230 L70 235" stroke="#8f9eb0" stroke-width="2"/><path d="M280 210 L330 205" stroke="#8f9eb0" stroke-width="2"/><path d="M280 220 L330 220" stroke="#8f9eb0" stroke-width="2"/><path d="M280 230 L330 235" stroke="#8f9eb0" stroke-width="2"/><ellipse cx="130" cy="215" rx="20" ry="12" fill="#e0e8f0" opacity="0.7"/><ellipse cx="2